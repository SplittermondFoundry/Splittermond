{
    "extends": "@tsconfig/node24",
    "compilerOptions": {
        "target": "es2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "paths": {
            "module/*": ["./src/module/*"],
            "__tests__/*": ["./src/__tests__/*"]
        },
        "rootDir": "./src",
        "noEmit": true,
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "lib": ["es2020", "dom"]
    },
    "include": ["src/**/*"],
}
