<section class="tab {{tabs.effects.id}} {{tabs.effects.cssClass}}" data-group="primary" data-tab="effects">
    <div class="effects-panel">
        <div class="effects-add">
            <input type="text" class="effect-modifier-input"
                   placeholder="{{localize 'splittermond.effectsPanel.inputPlaceholder'}}" />
            <button class="effect-add-button" type="button" data-action="add-effect">
                <i class="fas fa-plus" aria-hidden="true"></i>
                {{localize "splittermond.effectsPanel.add"}}
            </button>
        </div>
        {{#if effects.length}}
        <ol class="effects-list">
            {{#each effects}}
            <li class="effect-card{{#if this.disabled}} effect-disabled{{/if}}" data-effect-id="{{this.id}}">
                <div class="effect-card-content">
                    <span class="effect-name">{{this.name}}</span>
                    {{#if this.disabled}}
                    <span class="effect-disabled-badge">{{localize "splittermond.effectsPanel.disabled"}}</span>
                    {{/if}}
                </div>
                <div class="effect-card-actions">
                    <button class="button-inline" type="button" data-action="toggle-effect"
                            title="{{#if this.disabled}}Enable{{else}}Disable{{/if}}">
                        <i class="fa {{#if this.disabled}}fa-eye-slash{{else}}fa-eye{{/if}}" aria-hidden="true"></i>
                    </button>
                    <button class="button-inline" type="button" data-action="delete-effect">
                        <i class="fas fa-trash" aria-hidden="true"></i>
                    </button>
                </div>
            </li>
            {{/each}}
        </ol>
        {{else}}
        <p class="effects-empty">{{localize "splittermond.effectsPanel.empty"}}</p>
        {{/if}}
    </div>
</section>
